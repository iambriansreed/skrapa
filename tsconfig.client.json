{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./.scratch",
        "rootDir": "./",
        "lib": ["DOM", "DOM.Iterable", "ES2020"],
        "moduleResolution": "bundler"
    },
    "include": ["src/client.ts"],
    "exclude": ["node_modules", "dist"]
}
