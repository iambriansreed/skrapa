{
    "name": "stsx",
    "version": "0.1.0",
    "main": "index.js",
    "scripts": {
        "dev": "npx tsx src/dev.ts",
        "build": "tsc && tsc -p src/bin/tsconfig.json",
        "prepack": "chmod +x bin/scratch.js",
        "postversion": "npx tsx version.ts && git add scratch.ts src/index.tsx README.md",
        "format": "prettier --write src/**/*.{ts,tsx,json,css}",
        "lint": "eslint src/**/*.{ts,tsx}",
        "lint:css": "stylelint src/**/*.css",
        "test": "echo \"Error: no test specified\" && exit 1",
        "pack": "npm run build && npm pack && rm -f ../stsx-*.tgz && mv stsx-*.tgz ../ && cd .. && rm -rf package && tar -xzf stsx-*.tgz && cd package && npm link"
    },
    "files": [
        "bin/",
        "template/",
        "index.js",
        "global.d.ts"
    ],
    "bin": {
        "stsx": "bin/scratch.js"
    },
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@types/node": "^25.6.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=24"
    },
    "keywords": [],
    "description": ""
}
