{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "jsx": "react",
        "jsxFactory": "jsx",
        "jsxFragmentFactory": "Fragment",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./.tmp",
        "rootDir": "./",
        "lib": ["ES2020"],
        "types": ["node"]
    },
    "include": ["src/**/*", ".sys/**/*"],
    "exclude": ["node_modules", "dist", "src/client.ts"]
}
