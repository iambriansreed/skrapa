{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "jsx": "react",
        "jsxFactory": "jsx",
        "jsxFragmentFactory": "Fragment",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./.skrapa",
        "rootDir": "./",
        "lib": ["ES2020"],
        "types": ["node"],
        "typeRoots": ["./node_modules/@types"]
    },
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": ["node_modules", "dist", "template", "bin", "build", "src/**/client.ts"]
}
