{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "jsx": "react",
        "jsxFactory": "jsx",
        "jsxFragmentFactory": "Fragment",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "outDir": "../../bin",
        "rootDir": ".",
        "lib": ["ES2020"],
        "types": ["node"],
        "typeRoots": ["../../node_modules/@types"],
        "sourceMap": true
    },
    "include": ["./**/*.ts", "../../global.d.ts"],
    "exclude": ["../../node_modules", "../../bin", "../src/client.ts"]
}
