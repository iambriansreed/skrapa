{
    "name": "stsx",
    "version": "0.1.0",
    "main": "index.js",
    "scripts": {
        "dev": "npx tsx src/dev.ts",
        "build": "tsc && mkdir -p bin && cp .scratch/src/bin/scratch.js bin/scratch.js",
        "postbuild": "chmod +x bin/scratch.js",
        "format": "prettier --write src/**/*.{ts,tsx,json,css}",
        "lint": "eslint src/**/*.{ts,tsx}",
        "lint:css": "stylelint src/**/*.css",
        "test": "echo \"Error: no test specified\" && exit 1",
        "clean": "rm -rf dist bin .scratch",
        "dev-pack": "npm run build && npm pack && rm -f ../stsx-*.tgz && mv stsx-*.tgz ../ && cd .. && rm -rf package && tar -xzf stsx-*.tgz && cd package && npm link"
    },
    "files": [
        "bin/",
        "template/",
        "index.js",
        "global.d.ts"
    ],
    "bin": {
        "stsx": "bin/scratch.js"
    },
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@types/node": "^25.6.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=24"
    },
    "keywords": [],
    "description": "Build static sites with TypeScript JSX templates and TypeScript client-side code — no framework, no virtual DOM, no bundler config."
}
