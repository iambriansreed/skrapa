{
    "name": "stsx",
    "version": "0.0.9",
    "main": "index.js",
    "scripts": {
        "dev": "npx tsx src/dev.ts",
        "build": "tsc",
        "prepack": "chmod +x bin/scratch.js",
        "postversion": "npx tsx version.ts && git add scratch.ts src/index.tsx README.md",
        "format": "prettier --write src/**/*.{ts,tsx,json,css}",
        "lint": "eslint src/**/*.{ts,tsx}",
        "lint:css": "stylelint src/**/*.css",
        "test": "echo \"Error: no test specified\" && exit 1",
        "pack": "npm pack && mv stsx-*.tgz ../ && cd .. && tar -xzf stsx-*.tgz && cd package && npm link"
    },
    "files": [
        "bin/",
        "template/",
        "index.js"
    ],
    "bin": {
        "stsx": "./bin/scratch.js"
    },
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@types/node": "^25.6.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=24"
    },
    "keywords": [],
    "description": ""
}
